# Copy this file to .env for local development.
# Optional overlay:
# - .env.lightrag-provider.example (LLM/embedding for generated domain.env files)

# Application
APP_NAME=Context Engine
ENVIRONMENT=local
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_MINUTES=60

# Local host ports and backend base URLs
API_HOST=127.0.0.1
CLIENT_HOST=127.0.0.1
LIGHTRAG_HOST=127.0.0.1
PUBLISH_POSTGRES_PORT=5438
PUBLISH_REDIS_PORT=6386
API_PORT=8010
CLIENT_PORT=3007
CONTEXT_ENGINE_API_BASE_URL=http://127.0.0.1:8010
NEXT_PUBLIC_API_URL=http://127.0.0.1:8010
NEXT_PUBLIC_BACKEND_BASE_URL=http://127.0.0.1:8010
NEXT_PUBLIC_API_PORT=8010
NEXT_PUBLIC_LIGHTRAG_DEFAULT_PORT=9621

# Data stores
DATABASE_URL=postgresql+psycopg://context_engine:context_engine@localhost:5438/context_engine
REDIS_URL=redis://localhost:6386/0

# Runtime behavior
INDEX_JOBS_INLINE=false
STORAGE_ROOT=.data/uploads
ALLOWED_ORIGINS=*
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123

# LightRAG domain lifecycle (required)
LIGHTRAG_DEPLOY_ROOT=.data/lightrag
LIGHTRAG_DOMAINS_ROOT=.data/lightrag/domains
LIGHTRAG_DOMAIN_REGISTRY=.data/lightrag/domains.json
LIGHTRAG_COMPOSE_FILE=.data/lightrag/docker-compose.lightrag-domains.yml
LIGHTRAG_DELETED_ROOT=.data/lightrag/deleted
LIGHTRAG_TIMEOUT_SECONDS=10

LIGHTRAG_DEFAULT_PORT_START=9622
LIGHTRAG_DEFAULT_CONTAINER_PORT=9621
LIGHTRAG_DOCKER_NETWORK=context_engine_lightrag
LIGHTRAG_DOMAIN_ENV_FILENAME=domain.env
LIGHTRAG_DOCKER_EXECUTION_MODE=socket
LIGHTRAG_DOCKER_COMPOSE_BIN=docker compose
LIGHTRAG_DOCKER_TIMEOUT_SECONDS=120

# Generated-domain storage and cleanup settings
LIGHTRAG_DOCKERFILE=docker/lightrag.Dockerfile
LIGHTRAG_BUILD_CONTEXT=.
LIGHTRAG_STORAGE_BACKEND=postgres
LIGHTRAG_POSTGRES_URL=
LIGHTRAG_POSTGRES_HOST=postgres
LIGHTRAG_POSTGRES_PORT=5432
LIGHTRAG_POSTGRES_DATABASE_PREFIX=lightrag
LIGHTRAG_POSTGRES_USER_PREFIX=lightrag
LIGHTRAG_POSTGRES_PASSWORD=lightrag
LIGHTRAG_POSTGRES_PROVISIONING_MODE=per_domain
LIGHTRAG_POSTGRES_ADMIN_DATABASE=context_engine
LIGHTRAG_POSTGRES_VECTOR_EXTENSION=vector
LIGHTRAG_POSTGRES_AGE_EXTENSION=age
LIGHTRAG_POSTGRES_VECTOR_INDEX_TYPE=HNSW
LIGHTRAG_TOKENIZER_OFFLINE=true
LIGHTRAG_TIKTOKEN_CACHE_DIR=/app/.cache/tiktoken
LIGHTRAG_REDIS_URL=
LIGHTRAG_NEO4J_URI=
LIGHTRAG_NEO4J_USERNAME=
LIGHTRAG_NEO4J_PASSWORD=
LIGHTRAG_ARCHIVE_DELETED_DOMAINS=true
LIGHTRAG_ALLOW_PERMANENT_DELETE=false
