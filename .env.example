APP_NAME=Context Engine
ENVIRONMENT=local
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_MINUTES=60

POSTGRES_DB=context_engine
POSTGRES_USER=context_engine
POSTGRES_PASSWORD=context_engine
PUBLISH_POSTGRES_PORT=5438
PUBLISH_REDIS_PORT=6386
API_PORT=8000
CONTEXT_ENGINE_API_BASE_URL=http://127.0.0.1:8000

# If you change PUBLISH_* ports, set DATABASE_URL / REDIS_URL localhost ports to match.
DATABASE_URL=postgresql+psycopg://context_engine:context_engine@localhost:5438/context_engine
REDIS_URL=redis://localhost:6386/0
INDEX_JOBS_INLINE=false
STORAGE_ROOT=.data/uploads
ALLOWED_ORIGINS=*
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me

QUERY_LOG_STORE_TEXT=false
QUERY_LOG_RETENTION_DAYS=30

# ---------------------------------------------------------------------
# LightRAG runtime integration
# ---------------------------------------------------------------------
# LightRAG is mandatory for semantic retrieval and ingestion.
# This service does not provide local semantic fallback.
LIGHTRAG_BASE_URL=http://localhost:9621
LIGHTRAG_API_KEY=
LIGHTRAG_DOMAIN=default
LIGHTRAG_DOMAIN_MANIFEST=.data/lightrag/domains.json
LIGHTRAG_TIMEOUT_SECONDS=10
