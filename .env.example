# Copy this file to .env for local development.
# Optional overlays:
# - .env.lightrag-deploy.example (domain lifecycle via admin APIs)
# - .env.lightrag-provider.example (LLM/embedding for generated domain.env files)

# Application
APP_NAME=Context Engine
ENVIRONMENT=local
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_MINUTES=60

# Local host ports and backend base URLs
API_HOST=127.0.0.1
CLIENT_HOST=127.0.0.1
LIGHTRAG_HOST=127.0.0.1
PUBLISH_POSTGRES_PORT=5438
PUBLISH_REDIS_PORT=6386
API_PORT=8010
CLIENT_PORT=3007
CONTEXT_ENGINE_API_BASE_URL=http://127.0.0.1:8010
NEXT_PUBLIC_API_URL=http://127.0.0.1:8010
NEXT_PUBLIC_BACKEND_BASE_URL=http://127.0.0.1:8010
NEXT_PUBLIC_API_PORT=8010
NEXT_PUBLIC_LIGHTRAG_DEFAULT_PORT=9621

# Data stores
DATABASE_URL=postgresql+psycopg://context_engine:context_engine@localhost:5438/context_engine
REDIS_URL=redis://localhost:6386/0

# Runtime behavior
INDEX_JOBS_INLINE=false
STORAGE_ROOT=.data/uploads
ALLOWED_ORIGINS=*
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
LIGHTRAG_DEPLOY_ENABLED=true

# LightRAG runtime (required for upload/retrieve/graph flows)
LIGHTRAG_DOMAIN_REGISTRY=.data/lightrag/domains.json
LIGHTRAG_TIMEOUT_SECONDS=10
