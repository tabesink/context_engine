  "nodes": [
    {
      "id": "domain:authentication-and-access",
      "type": "domain",
      "name": "Authentication and Access Control",
      "summary": "Manages user identity, JWT issuance, and role-based authorization for all protected API routes. Distinguishes admin vs user capabilities for uploads, indexing, logs, and debug retrieval.",
      "tags": [
        "auth",
        "jwt",
        "rbac",
        "security"
      ],
      "complexity": "moderate",
      "domainMeta": {
        "entities": [
          "User",
          "UserRole",
          "AccessToken"
        ],
        "businessRules": [
          "All routes except health and login require authentication",
          "Admin-only operations use require_admin dependency",
          "V1: all authenticated users may read ready documents"
        ],
        "crossDomainInteractions": [
          "Gates document upload and indexing to admins",
          "Gates query debug details to admins",
          "Supplies user identity to retrieval query logging"
        ]
      }
    },
    {
      "id": "domain:document-lifecycle",
      "type": "domain",
      "name": "Document Lifecycle",
      "summary": "Owns uploaded source files, document registry metadata, parsed page/section structure, and authenticated read APIs for document discovery and inspection.",
      "tags": [
        "documents",
        "upload",
        "registry",
        "parsed-content"
      ],
      "complexity": "moderate",
      "domainMeta": {
        "entities": [
          "Document",
          "DocumentStatus",
          "ParsedDocument",
          "Page"
        ],
        "businessRules": [
          "Only admins may upload or delete documents",
          "Soft delete preserves history; ready non-deleted docs are queryable by all authenticated users",
          "Local path stores files under STORAGE_ROOT; remote path mirrors metadata locally"
        ],
        "crossDomainInteractions": [
          "Triggers indexing jobs after local upload",
          "Forwards uploads to LightRAG when enabled",
          "Provides document scope for retrieval queries"
        ]
      }
    },
    {
      "id": "domain:indexing-and-jobs",
      "type": "domain",
      "name": "Indexing and Background Jobs",
      "summary": "Transforms uploaded documents into queryable indexes via parsing, navigation tree construction, and semantic chunking. Job queue tracks async indexing with failure isolation.",
      "tags": [
        "indexing",
        "jobs",
        "worker",
        "parsing"
      ],
      "complexity": "complex",
      "domainMeta": {
        "entities": [
          "Job",
          "JobStatus",
          "NavigationIndex",
          "SemanticChunk"
        ],
        "businessRules": [
          "Failed indexing does not replace the previous active index version",
          "INDEX_JOBS_INLINE=true runs indexing synchronously for local dev/tests",
          "Indexing builds from ParsedDocument, not raw upload bytes alone"
        ],
        "crossDomainInteractions": [
          "Activated by document upload or admin reindex",
          "Produces indexes consumed by retrieval engines",
          "Writes audit events on document state changes"
        ]
      }
    },
    {
      "id": "domain:knowledge-retrieval",
      "type": "domain",
      "name": "Knowledge Retrieval and Answers",
      "summary": "Answers user questions by retrieving Evidence from semantic, navigation, or hybrid strategies, optionally composing grounded answers with citations and refusal on weak evidence.",
      "tags": [
        "rag",
        "retrieval",
        "evidence",
        "answers"
      ],
      "complexity": "complex",
      "domainMeta": {
        "entities": [
          "Evidence",
          "RetrievalMode",
          "RetrievalResult",
          "QueryRequest"
        ],
        "businessRules": [
          "All engines return unified Evidence contract",
          "mode=auto routes locally when LightRAG disabled; remote maps auto/semantic/hybrid to mix when enabled",
          "Weak evidence refuses answer unless allow_general_fallback=true"
        ],
        "crossDomainInteractions": [
          "Reads document indexes built by indexing domain",
          "Delegates semantic/hybrid/auto to LightRAG when feature flag on",
          "Records query logs for operations observability"
        ]
      }
    },
    {
      "id": "domain:lightrag-integration",
      "type": "domain",
      "name": "LightRAG Remote Integration",
      "summary": "Optional HTTP integration for remote retrieval, multipart upload forwarding, ingestion status tracking, and read-only knowledge-graph proxy routes.",
      "tags": [
        "lightrag",
        "integration",
        "remote",
        "graph-proxy"
      ],
      "complexity": "moderate",
      "domainMeta": {
        "entities": [
          "LightRAGRemoteAdapter",
          "LightRAG track_id",
          "Domain manifest"
        ],
        "businessRules": [
          "LIGHTRAG_ENABLED=false keeps all retrieval local except navigation always local",
          "Graph proxy routes return disabled-service error when LightRAG off",
          "Remote upload may return job_id null; status tracked via lightrag metadata"
        ],
        "crossDomainInteractions": [
          "Replaces local semantic/hybrid/auto retrieval backend when enabled",
          "Receives admin uploads forwarded from document lifecycle",
          "Exposes graph exploration separate from local Evidence API"
        ]
      }
    },
    {
      "id": "domain:platform-operations",
      "type": "domain",
      "name": "Platform Operations and Observability",
      "summary": "Supports health checks, job inspection/retry, audit and query logs for operators, plus ragcli as an API client mirror of backend routes.",
      "tags": [
        "operations",
        "health",
        "logging",
        "cli"
      ],
      "complexity": "simple",
      "domainMeta": {
        "entities": [
          "AuditLog",
          "QueryLog",
          "Health endpoints"
        ],
        "businessRules": [
          "Health routes are public",
          "Job retry limited to admin workflows",
          "CLI calls backend routes; does not embed business logic"
        ],
        "crossDomainInteractions": [
          "Observes indexing job state transitions",
          "Captures retrieval query metrics from knowledge retrieval"
        ]
      }
    },
